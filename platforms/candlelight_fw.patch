+struct gs_device_filter {
+	uint8_t dev; /* device, CANFILTER_DEV_BXCAN for bxcan with 14 registers */
+	uint8_t reserved[3];
+	uint32_t fs1r;
+	uint32_t fm1r;
+	uint32_t ffa1r;
+	uint32_t fa1r;
+	uint32_t fr1[14];
+	uint32_t fr2[14];
+} __packed __aligned(4);

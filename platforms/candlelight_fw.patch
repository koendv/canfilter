+// gs_usb filter protocol: answer to repurposed GET_USER_ID
+
+#define CANFILTER_DEV_BXCAN_F0 1 /* bxcan, 14 filters */
+
+struct gs_filter_info {
+	uint8_t dev;     /* device, CANFILTER_DEV_BXCAN_F0 for bxcan with 14 registers */
